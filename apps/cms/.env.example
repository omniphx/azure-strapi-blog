# Server
HOST=0.0.0.0
PORT=1337
APP_KEYS=your-app-key-1,your-app-key-2,your-app-key-3,your-app-key-4
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-token-salt
JWT_SECRET=your-jwt-secret

# Database (SQLite - local development)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Database (PostgreSQL - Azure production)
# DATABASE_CLIENT=postgres
# DATABASE_HOST=your-azure-postgres-host.postgres.database.azure.com
# DATABASE_PORT=5432
# DATABASE_NAME=strapi
# DATABASE_USERNAME=your-db-user
# DATABASE_PASSWORD=your-db-password
# DATABASE_SSL=true

# Azure Blob Storage (for uploads in production)
# STORAGE_PROVIDER=azure
# STORAGE_AZURE_ACCOUNT_NAME=your-storage-account
# STORAGE_AZURE_ACCOUNT_KEY=your-storage-key
# STORAGE_AZURE_CONTAINER_NAME=strapi-uploads
# STORAGE_AZURE_CDN_URL=https://your-cdn.azureedge.net
